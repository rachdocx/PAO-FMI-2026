<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.SignInController">
    <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0"/></padding>

    <Label text="Log in into your Rachify Account" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="email_field" promptText="Email"/>
    <PasswordField fx:id="password_field" promptText="Password"/>

    <Button text="Sign In" onAction="#onSignInClick" style="-fx-background-color: #1DB954; -fx-text-fill: white;"/>
    <Label fx:id="auth_state" textFill="red"/>
</VBox>